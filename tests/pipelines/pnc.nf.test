            def actual_arborview1 = path("$launchDir/results/arborview/Outbreak1_arborview.html")
            assert actual_arborview1.exists()
            assert actual_arborview1.text.contains("sample_name\\tsample\\tnew_isolates_date\\tpredicted_primary_identification_name\\tpredicted_primary_type_name\\tnational_outbreak_code\\tnational_outbreak_status\\tprovisional_outbreak_code\\trelated_specimen_primary_id\\trelated_specimen_relationship_type\\tcalc_source_type\\tgeo_loc_name_country\\tgeo_loc_name_state_province_territory\\tpnc_analysis_date\\tcnphi_post_date\\tcalc_earliest_date\\tfastmatch_result\\tgenomic_address_name\\tgas_denovo_cluster_address\\nA\\tA\\t2025-01-01\\tSalmonella enterica\\tEnteritidis\\tOutbreak1\\tclosed\\tOutbreak1\\t\\t\\tHuman\\tUnited States\\t\\t2025-01-06\\t2025-01-08\\t2024-12-01\\t\\t1.1.1.1.1.1\\tOutbreak1|1.1.1.1.1.1\\nB\\tB\\t2025-01-01\\tSalmonella enterica\\tEnteritidis\\tOutbreak1\\tclosed\\tOutbreak1\\t\\t\\tAnimal\\tCanada\\tQC\\t2025-01-06\\t2025-01-08\\t2024-12-02\\t\\t1.1.1.1.1.1\\tOutbreak1|1.1.1.1.1.1\\nC\\tC\\t2025-01-01\\tSalmonella enterica\\tEnteritidis\\tOutbreak1\\tclosed\\tOutbreak1\\t\\t\\tHuman\\tCanada\\tBC\\t2025-01-06\\t2025-01-08\\t2024-12-03\\t\\t1.1.1.1.1.1\\tOutbreak1|1.1.1.1.1.1\\nD\\tD\\t2025-01-01\\tSalmonella enterica\\tEnteritidis\\tOutbreak1\\tclosed\\tOutbreak1\\t\\t\\tAnimal\\tCanada\\tMB\\t2025-01-06\\t2025-01-08\\t2024-12-04\\t\\t1.1.1.1.1.1\\tOutbreak1|1.1.1.1.1.1")

            def actual_arborview2 = path("$launchDir/results/arborview/Outbreak2_arborview.html")
            assert actual_arborview2.exists()
            assert actual_arborview2.text.contains("sample_name\\tsample\\tnew_isolates_date\\tpredicted_primary_identification_name\\tpredicted_primary_type_name\\tnational_outbreak_code\\tnational_outbreak_status\\tprovisional_outbreak_code\\trelated_specimen_primary_id\\trelated_specimen_relationship_type\\tcalc_source_type\\tgeo_loc_name_country\\tgeo_loc_name_state_province_territory\\tpnc_analysis_date\\tcnphi_post_date\\tcalc_earliest_date\\tfastmatch_result\\tgenomic_address_name\\tgas_denovo_cluster_address\\nE\\tE\\t2025-01-01\\tSalmonella enterica\\tEnteritidis\\tOutbreak2\\topen\\tOutbreak2\\t\\t\\tHuman\\tCanada\\tAB\\t2025-01-06\\t2025-01-08\\t2024-12-05\\t\\t1.1.1.1.1.2\\tOutbreak2|1.1.1.1.1.1\\nF\\tF\\t2025-01-01\\tSalmonella enterica\\tEnteritidis\\tOutbreak2\\topen\\tOutbreak2\\t\\t\\tHuman\\tCanada\\tAB\\t2025-01-06\\t2025-01-08\\t2024-12-05\\t\\t1.1.1.1.1.2\\tOutbreak2|1.1.1.1.1.1")

            // compare IRIDA Next JSON output
            def iridanext_json = path("$launchDir/results/iridanext.output.json").json
            def iridanext_global = iridanext_json.files.global
            def iridanext_samples = iridanext_json.files.samples
            def iridanext_metadata = iridanext_json.metadata.samples

            assert iridanext_global.findAll { it.path == "arborator/Outbreak1_clusters.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak1_loci.summary.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak1_matrix.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak1_metadata.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak1_outliers.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak1_profile.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak1_tree.nwk" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak2_clusters.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak2_loci.summary.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak2_matrix.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak2_metadata.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak2_outliers.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak2_profile.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/Outbreak2_tree.nwk" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/cluster_summary.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/metadata.excluded.tsv" }.size() == 1
            assert iridanext_global.findAll { it.path == "arborator/metadata.included.tsv" }.size() == 1

            assert iridanext_samples.isEmpty()
            assert iridanext_metadata.isEmpty()
        }
    }
}
